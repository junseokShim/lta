# ===== Local Team Agent 환경 설정 =====

# 작업 공간 기본 경로
WORKSPACE_ROOT=./workspaces

# Ollama 서버 설정 (로컬 실행 시)
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma4:26b
OLLAMA_FAST_MODEL=gemma4:26b
OLLAMA_VISION_MODEL=llava:7b

# HuggingFace 설정 (transformers 백엔드 사용 시)
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2
HF_DEVICE=cuda  # cuda / cpu / mps
HF_LOAD_IN_4BIT=true
HF_LOAD_IN_8BIT=false

# 백엔드 선택: ollama / transformers / llamacpp
DEFAULT_BACKEND=ollama
BACKEND_TIMEOUT=120
BACKEND_RETRY_ATTEMPTS=3

# 인터넷 검색 설정
WEB_SEARCH_PROVIDER=duckduckgo
# SERPAPI_API_KEY=

# 로깅
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# 웹 UI 설정
UI_HOST=0.0.0.0
UI_PORT=8501

# 도구 설정
MAX_SHELL_TIMEOUT=60
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.txt,.md,.py,.js,.ts,.json,.yaml,.yml,.csv,.html,.css,.pdf,.docx,.pptx

# RAG 설정
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# 에이전트 설정
MAX_ITERATIONS=10
AGENT_TIMEOUT=120
